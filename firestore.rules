rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function: does the document belong to this user?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Habits collection
    match /habits/{habitId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Tasks / Todos collection
    match /todos/{taskId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Calendar events collection
    match /calendar-events/{eventId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Analytics collection
    match /analytics/{analyticsId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Goals collection
    match /goals/{goalId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Reflections collection
    match /reflections/{reflectionId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // User profiles collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Any other top-level collection — deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
